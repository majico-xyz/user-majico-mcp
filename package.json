{
  "name": "@majico/mcp",
  "version": "0.8.5",
  "description": "MCP server for Majico.xyz: brand guidelines, design tokens, studio canvas (Pro projects).",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/majico-xyz/user-majico-mcp.git"
  },
  "homepage": "https://github.com/majico-xyz/user-majico-mcp#readme",
  "bugs": {
    "url": "https://github.com/majico-xyz/majico.xyz/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "majico-mcp": "dist/index.js",
    "user-majico-mcp": "dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./http": {
      "types": "./dist/http-handler.d.ts",
      "import": "./dist/http-handler.js"
    },
    "./auth-prompt": {
      "types": "./dist/auth-prompt.d.ts",
      "import": "./dist/auth-prompt.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run typecheck && npm run build && npm test"
  },
  "keywords": [
    "mcp",
    "majico",
    "brand",
    "design-tokens"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "sharp": "^0.34.5"
  },
  "peerDependencies": {
    "@majico/sdk": ">=1.1.1"
  },
  "devDependencies": {
    "@majico/sdk": "file:../majico-sdk",
    "@types/node": "^22.19.0",
    "typescript": "^5.9.0",
    "vitest": "4.1.6"
  },
  "engines": {
    "node": ">=18"
  }
}
